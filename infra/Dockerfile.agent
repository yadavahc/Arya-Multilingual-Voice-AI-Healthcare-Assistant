# LiveKit voice agent worker — deploy near users (asia-south1) with a warm pool.
FROM python:3.12-slim

WORKDIR /app
ENV PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY apps/agent/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY apps/agent/ ./

# Pre-download model weights (Silero VAD, turn detector) into the image.
RUN python agent.py download-files || true

CMD ["python", "agent.py", "start"]
