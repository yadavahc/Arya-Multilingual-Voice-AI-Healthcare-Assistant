# ─────────────────────────────────────────────────────────────
# Arya — Environment Variables
# Copy to `.env` (root, for agent + api) and `apps/web/.env.local` (for web).
# NEXT_PUBLIC_* vars must live in apps/web/.env.local to reach the browser.
# ─────────────────────────────────────────────────────────────

# ── AI ──────────────────────────────────────────────────────
OPENAI_API_KEY=                    # Realtime API + GPT-4.1 for notes
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_NOTES_MODEL=gpt-4.1-mini
SARVAM_API_KEY=                    # Indian-language STT+TTS (Hindi/Kannada/Tamil/English)
DEEPGRAM_API_KEY=                  # fallback STT (optional)
CARTESIA_API_KEY=                  # fallback TTS (optional)

# ── Voice infra (LiveKit) ───────────────────────────────────
LIVEKIT_URL=                       # wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=           # same wss:// url, exposed to browser

# ── Telephony ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
EXOTEL_SID=                        # India alternative
EXOTEL_TOKEN=

# ── Firebase (client — put NEXT_PUBLIC_* in apps/web/.env.local) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=     # base64-encoded service account, for Admin SDK

# ── Payments ────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=                 # optional international

# ── Data ────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
PINECONE_API_KEY=                  # optional, for guideline RAG

# ── Messaging ───────────────────────────────────────────────
WHATSAPP_BUSINESS_TOKEN=           # Meta Cloud API, optional
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ── Ops ─────────────────────────────────────────────────────
SENTRY_DSN=

# ── Service wiring ──────────────────────────────────────────
API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
AGENT_REGION=asia-south1
